{
  "name": "why-is-this",
  "version": "0.1.0",
  "description": "Trace the 'why' behind any line of code — git blame, PR context, rationale annotations, fear scoring",
  "keywords": [
    "git",
    "blame",
    "code-archaeology",
    "decision",
    "rationale",
    "adr",
    "developer-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mukesh7522/Why-is-this.git"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "why-is-this": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "jest",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@why-is-this/core": "*",
    "@why-is-this/embeddings": "*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.6.1",
    "inquirer": "^9.0.0",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "*",
    "@types/jest": "*",
    "jest": "*",
    "ts-jest": "*",
    "typescript": "*"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ]
  }
}
